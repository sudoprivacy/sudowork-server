# ============================================
# Sudowork-Server Environment Configuration
# Copy this file to .env and configure values
# ============================================

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
# Redis host (use 'redis' for docker-compose)
REDIS_HOST=redis
# Redis port
REDIS_PORT=6379
# Redis password (leave empty if no password)
REDIS_PASSWORD=

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# SQLite database file path
DB_PATH=/app/data/sudowork.db

# --------------------------------------------
# Server Configuration
# --------------------------------------------
# Server port
SERVER_PORT=3000

# --------------------------------------------
# Security Configuration (REQUIRED)
# --------------------------------------------
# JWT secret key (REQUIRED in production)
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=

# Super Admin Credentials (REQUIRED for initial setup)
# Super admin login phone/username
SUPER_ADMIN_PHONE=sudo
# Super admin login password (REQUIRED, change this in production!)
SUPER_ADMIN_PASSWORD=

# --------------------------------------------
# SMS Provider Configuration
# --------------------------------------------
# SMS provider: 'mock' for testing, 'tencent' for production
SMS_PROVIDER=mock

# Tencent Cloud SMS Credentials (required if SMS_PROVIDER=tencent)
# Get these from: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Tencent Cloud SMS Settings
# Get SDK App ID from: https://console.cloud.tencent.com/smsv2
TENCENT_SDK_APP_ID=
# SMS signature name (must be approved)
TENCENT_SIGN_NAME=
# SMS template ID (must be approved)
TENCENT_TEMPLATE_ID=
# SMS signature ID (optional)
TENCENT_SIGN_ID=
# Tencent Cloud region
TENCENT_REGION=ap-beijing

# --------------------------------------------
# Verification Code Configuration (Phone-level)
# --------------------------------------------
# Verification code length (4 or 6 digits)
SMS_CODE_LENGTH=6
# Verification code expiration time (minutes)
SMS_CODE_EXPIRE_MINUTES=5
# Minimum interval between sending codes (seconds)
SMS_CODE_SEND_INTERVAL=60
# Maximum number of codes per day per phone
SMS_CODE_MAX_PER_DAY=10

# --------------------------------------------
# Rate Limiting Configuration (IP-level)
# --------------------------------------------
# Enable rate limiting
RATE_LIMIT_ENABLED=true
# Login rate limit: time window in milliseconds (default: 15 minutes)
RATE_LIMIT_LOGIN_WINDOW_MS=900000
# Login rate limit: max requests per IP per window
RATE_LIMIT_LOGIN_MAX=10
# API rate limit: time window in milliseconds (default: 1 minute)
RATE_LIMIT_API_WINDOW_MS=60000
# API rate limit: max requests per IP per window
RATE_LIMIT_API_MAX=100

# --------------------------------------------
# Sudorouter Configuration
# --------------------------------------------
# Sudorouter API base URL
SUDOROUTER_BASE_URL=http://10.0.1.8:3000
# Sudorouter API token
SUDOROUTER_API_TOKEN=
# Sudorouter admin user ID
SUDOROUTER_ADMIN_USER_ID=13
# Sudorouter request timeout (milliseconds)
SUDOROUTER_TIMEOUT_MS=10000
# Sudorouter model service URL
SUDOROUTER_MODEL_SERVICE_URL=http://10.0.1.8:3000/v1
# Sudorouter models API URL
SUDOROUTER_MODELS_API_URL=https://chat.sudorouter.ai/api/specific_pricing

# --------------------------------------------
# User Configuration
# --------------------------------------------
# Initial quota for new users (default: 500000 = 1000 points)
USER_INITIAL_QUOTA=500000